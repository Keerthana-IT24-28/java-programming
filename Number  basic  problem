class Solution {
    public int differenceOfSum(int[] nums) {
        int sum1=0;
        int sum2= 0;
        for(int x : nums){
            sum1=sum1+x;
            int y=x;
            while(y>0){
                int r=y%10;
                sum2=sum2+r;
                y=y/10;
            }
        }
            return Math.abs(sum1-sum2);
        }
      
    }
